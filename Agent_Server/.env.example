# AI Test Agent 后端配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ai_test_agent

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8001
DEBUG=True

# CORS 配置（逗号分隔多个来源）
CORS_ORIGINS=http://localhost:5175,http://localhost:3000

# ============================================
# Browser-Use 配置
# ============================================
# 浏览器启动参数
BROWSER_PATH=
BROWSER_USER_DATA=
BROWSER_DEBUGGING_PORT=9222
BROWSER_DEBUGGING_HOST=localhost
KEEP_BROWSER_OPEN=true
USE_OWN_BROWSER=false
BROWSER_CDP=
HEADLESS=false
DISABLE_SECURITY=false

# 路径配置
SAVE_RECORDING_PATH=./tmp/record_videos
SAVE_TRACE_PATH=./tmp/traces
SAVE_AGENT_HISTORY_PATH=./tmp/agent_history
SAVE_DOWNLOAD_PATH=./tmp/downloads

# Browser-Use 日志级别
BROWSER_USE_LOGGING_LEVEL=info
ANONYMIZED_TELEMETRY=false

# Agent 执行配置
LLM_PROVIDER=alibaba
LLM_USE_VISION=true
MAX_STEPS=100
MAX_ACTIONS=10
MAX_INPUT_TOKENS=128000
TOOL_CALLING_METHOD=function_calling

# 窗口尺寸
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1200

# ============================================
# MinIO 对象存储配置
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aitest
MINIO_REGION=cn-beijing-1
MINIO_SECURE=false

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/2

# ============================================
# Pentest_Agent — Docker & Runtime Configuration
# ============================================
# 是否使用 Docker 沙箱执行安全工具（true=容器隔离; false=宿主机直装模式）
PENTEST_USE_DOCKER=true

# 渗透测试 Docker 镜像（Kali Linux 全工具镜像）
PENTEST_DOCKER_IMAGE=vxcontrol/kali-linux

# 容器内工作目录
PENTEST_DOCKER_WORKDIR=/workspace

# 产物保存根目录（宿主机路径，会挂载进容器）
PENTEST_ARTIFACT_PATH=../save_floder/pentest

# Agent 最大迭代轮次
PENTEST_MAX_ITERATIONS=100

# Reflector 最大调用次数/链
PENTEST_MAX_REFLECTOR_ROUNDS=3

# LLM 单轮最大 token（建议 4096，避免超出模型限制）
PENTEST_LLM_MAX_TOKENS=4096

# 单次工具调用超时（秒）
PENTEST_TOOL_TIMEOUT=300

# ============================================
# Pentest_Agent — Tool Configuration
# ============================================
# Terminal 工具配置
TOOL_TERMINAL_TIMEOUT=300
TOOL_TERMINAL_OUTPUT_LIMIT=20000

# File 工具配置
TOOL_FILE_READ_LIMIT=50000
TOOL_FILE_ALLOW_DELETE=true

# Browser 工具配置
TOOL_BROWSER_TIMEOUT=60
TOOL_BROWSER_RESPONSE_LIMIT=30000
TOOL_BROWSER_VERIFY_SSL=false

# Search 工具配置
TOOL_SEARCH_TIMEOUT=20
TOOL_SEARCH_MAX_RESULTS=10

# Scanner 工具配置
TOOL_SCANNER_TIMEOUT=600
TOOL_SCANNER_OUTPUT_LIMIT=50000

# ============================================
# Pentest_Agent — Browser Tool Configuration
# ============================================
# 浏览器模式: http(requests) | selenium | playwright
PENTEST_BROWSER_MODE=http

# 浏览器操作超时（秒）
PENTEST_BROWSER_TIMEOUT=60

# ============================================
# Pentest_Agent — Search & Intelligence Configuration
# ============================================
# SearXNG 自建搜索实例（留空则跳过）
PENTEST_SEARXNG_URL=

# Sploitus exploit 情报源
PENTEST_SPLOITUS_URL=https://sploitus.com

# ============================================
# Pentest_Agent — Knowledge Graph Configuration
# ============================================
# Graphiti 服务 URL（留空则禁用知识图谱）
PENTEST_GRAPHITI_URL=

# Graphiti 超时时间（秒）
PENTEST_GRAPHITI_TIMEOUT=30

# 是否启用知识图谱
PENTEST_GRAPHITI_ENABLED=false

# ============================================
# Pentest_Agent — Observability Configuration
# ============================================
# 是否启用可观测性
OBSERVABILITY_ENABLED=false

# Langfuse 配置
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry 配置
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ============================================
# Pentest_Agent — Real-time Push Configuration
# ============================================
# 是否启用实时推送
PENTEST_REALTIME_PUSH_ENABLED=true

# WebSocket 端口
PENTEST_WEBSOCKET_PORT=8001

# SSE 端口
PENTEST_SSE_PORT=8002

# ============================================
# Pentest_Agent — Security Tool Paths
# ============================================
# 注意：当 PENTEST_USE_DOCKER=true 时，这些路径是容器内的路径
# vxcontrol/kali-linux 镜像已预装所有工具，直接使用命令名即可

# Nmap 网络扫描工具
PENTEST_NMAP_PATH=/usr/bin/nmap
NMAP_PATH=/usr/bin/nmap

# Nuclei 漏洞扫描框架
PENTEST_NUCLEI_PATH=/usr/local/bin/nuclei
NUCLEI_PATH=/usr/local/bin/nuclei

# Nuclei 模板目录
PENTEST_NUCLEI_TEMPLATES_PATH=/root/nuclei-templates
NUCLEI_TEMPLATES_PATH=/root/nuclei-templates

# SQLMap SQL 注入测试工具
PENTEST_SQLMAP_PATH=/usr/bin/sqlmap
SQLMAP_PATH=/usr/bin/sqlmap

# XSStrike XSS 测试工具
PENTEST_XSSTRIKE_PATH=/usr/bin/xsstrike
XSSTRIKE_PATH=/usr/bin/xsstrike

# FFUF Web 模糊测试
PENTEST_FFUF_PATH=/usr/bin/ffuf
FFUF_PATH=/usr/bin/ffuf

# Gobuster 目录/文件枚举
PENTEST_GOBUSTER_PATH=/usr/bin/gobuster
GOBUSTER_PATH=/usr/bin/gobuster

# Metasploit 渗透框架
PENTEST_METASPLOIT_PATH=/usr/bin/msfconsole
METASPLOIT_PATH=/usr/bin/msfconsole

# Hydra 暴力破解工具
PENTEST_HYDRA_PATH=/usr/bin/hydra

# Amass 子域名枚举
PENTEST_AMASS_PATH=/usr/bin/amass

# Wordlist 目录（SecLists）
PENTEST_WORDLIST_PATH=/usr/share/wordlists

# ============================================
# Pentest_Agent — Advanced Features
# ============================================
# 执行监控配置
EXECUTION_MONITOR_ENABLED=false
EXECUTION_MONITOR_SAME_TOOL_LIMIT=5
EXECUTION_MONITOR_TOTAL_TOOL_LIMIT=10

# 链摘要配置
SUMMARIZER_PRESERVE_LAST=true
SUMMARIZER_LAST_SEC_BYTES=51200
SUMMARIZER_MAX_BP_BYTES=16384

# 向量搜索配置
VECTOR_SEARCH_THRESHOLD=0.2
VECTOR_SEARCH_LIMIT=3

# ============================================
# 文件存储配置
# ============================================
SAVE_FOLDER_DIR=../save_floder
SAVE_IMG_DIR=../save_img
BUG_IMG_PATH=../save_floder/bug_img
VL_ANALYSIS_DIR=../save_img/vl_analysis

# ============================================
# Python 环境配置
# ============================================
PYTHON_PATH=python

# ============================================
# API 测试配置
# ============================================
API_BASE_URL=http://your-api-server:81
API_TOKEN=

# ============================================
# 邮件服务配置
# ============================================
# 通过数据库 email_config 表配置


# ============================================================
# PressTest_Agent — Performance Testing Configuration
# ============================================================
# Docker & Runtime
PRESSTEST_USE_DOCKER=true
PRESSTEST_DOCKER_NETWORK=presstest-network
PRESSTEST_ARTIFACT_PATH=../save_floder/presstest

# Engine Images
PRESSTEST_K6_IMAGE=grafana/k6:latest
PRESSTEST_K6_TIMEOUT=600

PRESSTEST_LOCUST_IMAGE=locustio/locust:latest
PRESSTEST_LOCUST_TIMEOUT=600
PRESSTEST_LOCUST_WEB_PORT=8089

PRESSTEST_JMETER_IMAGE=justb4/jmeter:latest
PRESSTEST_JMETER_TIMEOUT=600

# Execution Limits
PRESSTEST_MAX_CONCURRENT_TASKS=5
PRESSTEST_TASK_TIMEOUT=3600
PRESSTEST_MAX_VUS=10000
PRESSTEST_MAX_DURATION=3600
PRESSTEST_MAX_RPS=100000

# Monitoring (Optional)
PRESSTEST_PROMETHEUS_ENABLED=false
PRESSTEST_PROMETHEUS_URL=
PRESSTEST_GRAFANA_ENABLED=false
PRESSTEST_GRAFANA_URL=

# Real-time Push
PRESSTEST_REALTIME_PUSH_ENABLED=true
