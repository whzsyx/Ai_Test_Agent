# 环境变量配置示例文件
APP_NAME=Enterprise AI QA Agent
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LLM_REQUEST_TIMEOUT_SECONDS=60

# ArangoDB 配置
ARANGO_HOST=127.0.0.1
ARANGO_PORT=8529
ARANGO_USERNAME=root
ARANGO_PASSWORD=qwer4321
ARANGO_DATABASE=QA_Agent
ARANGO_TIMEZONE=Asia/Shanghai
ARANGO_SESSION_COLLECTION=agent_sessions
ARANGO_MESSAGE_COLLECTION=agent_session_messages
ARANGO_EVENT_COLLECTION=agent_session_events
ARANGO_SNAPSHOT_COLLECTION=agent_session_snapshots
ARANGO_APPROVAL_COLLECTION=agent_session_approvals
ARANGO_TOOL_JOB_COLLECTION=agent_tool_jobs
ARANGO_TOOL_ARTIFACT_COLLECTION=agent_tool_artifacts
ARANGO_MEMORY_COLLECTION=agent_memory

# 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=qwer4321
MYSQL_DATABASE=QA_Agent
MYSQL_CHARSET=utf8mb4
LLM_MODEL_TABLE=llm_model_config
EMAIL_CONFIG_TABLE=system_email_config
MEMORY_TOP_K=6
TOOL_JOB_HEARTBEAT_TIMEOUT_SECONDS=90

# Artifact object storage
ARTIFACT_STORAGE_BACKEND=minio
ARTIFACT_KEEP_LOCAL_COPY=false
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qa-agent
MINIO_SECURE=false
