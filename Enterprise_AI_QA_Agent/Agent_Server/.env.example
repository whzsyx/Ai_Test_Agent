APP_NAME='Enterprise AI QA Agent'
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LLM_REQUEST_TIMEOUT_SECONDS=60

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=qwer4321
MYSQL_DATABASE=QA_Agent
MYSQL_CHARSET=utf8mb4

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=QA-Agent
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_POOL_SIZE=12
POSTGRES_MEMORY_TABLE=agent_memories
POSTGRES_SESSION_TABLE=agent_sessions
POSTGRES_MESSAGE_TABLE=agent_session_messages
POSTGRES_EVENT_TABLE=agent_session_events
POSTGRES_SNAPSHOT_TABLE=agent_session_snapshots
POSTGRES_APPROVAL_TABLE=agent_session_approvals
POSTGRES_TOOL_JOB_TABLE=agent_tool_jobs
POSTGRES_TOOL_ARTIFACT_TABLE=agent_tool_artifacts
POSTGRES_VECTOR_DIMENSION=1536

MEMGRAPH_HOST=127.0.0.1
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

LLM_MODEL_TABLE=llm_model_config
EMAIL_CONFIG_TABLE=system_email_config
CHANNEL_CONFIG_TABLE=system_channel_config
# Set a stable secret or a Fernet key before saving QQ/Feishu/Lark/Weixin tokens.
CHANNEL_CREDENTIAL_ENCRYPTION_KEY=
REDIS_URL=redis://127.0.0.1:6379/0
# Persistent server-side credential root. Mount this path on durable storage and
# always run Agent Server under the same OS service account (Windows DPAPI).
AGENTLY_CLI_CONFIG_ROOT=data/agently_mail_profiles
AGENTLY_AUTH_LOCK_TTL_SECONDS=600
AGENTLY_AUTH_LOCK_WAIT_SECONDS=30
AGENTLY_AUTH_CHECK_INTERVAL_SECONDS=300
DOCKER_MANAGED_CONTAINER_PREFIX=qa-agent
DOCKER_MANAGED_VOLUME_ROOT=data/docker-volumes
DOCKER_REDIS_IMAGE=redis:7-alpine
DOCKER_MINIO_IMAGE=minio/minio:latest
DOCKER_MYSQL_IMAGE=mysql:8.4
DOCKER_POSTGRES_IMAGE=postgres:16-alpine
DOCKER_MEMGRAPH_IMAGE=memgraph/memgraph:latest
MEMORY_BACKEND=postgres
SESSION_BACKEND=postgres
TOOL_JOB_BACKEND=postgres
UI_GRAPH_BACKEND=memgraph
MEMORY_TOP_K=6
TOOL_JOB_HEARTBEAT_TIMEOUT_SECONDS=90
MCP_STDIO_COMMAND_ALLOWLIST=["npx","uvx","node","python","python3"]

ARTIFACT_STORAGE_BACKEND=minio
ARTIFACT_KEEP_LOCAL_COPY=false
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qa-agent
MINIO_SECURE=false
MINIO_UPLOAD_TEMP_BUCKET=upload-temp
MINIO_UPLOAD_SAFE_BUCKET=upload-safe
MINIO_UPLOAD_QUARANTINE_BUCKET=upload-quarantine
UPLOAD_SCAN_MAX_BYTES=10485760
UPLOAD_SCAN_MEDIUM_RISK_THRESHOLD=30
UPLOAD_SCAN_HIGH_RISK_THRESHOLD=70

# Security testing runner
SECURITY_RUNNER_BACKEND=docker
SECURITY_RUNNER_DOCKER_IMAGE=vxcontrol/kali-linux
SECURITY_RUNNER_DOCKER_CONTAINER_PREFIX=qa-security-runner
SECURITY_RUNNER_DOCKER_WORKDIR=/work
SECURITY_RUNNER_DOCKER_NETWORK=
SECURITY_RUNNER_DOCKER_NET_RAW=true
SECURITY_RUNNER_DOCKER_NET_ADMIN=true
SECURITY_RUNNER_DOCKER_PULL_POLICY=never
SECURITY_RUNNER_CONTAINER_REUSE=false
SECURITY_RUNNER_DOCKER_CLEANUP_AFTER_RUN=true
SECURITY_RUNNER_WRAP_TIMEOUT=true

# Performance testing runner
PERFORMANCE_RUNNER_BACKEND=auto
PERFORMANCE_RUNNER_EPHEMERAL=true
PERFORMANCE_DEFAULT_ENGINE=k6
PERFORMANCE_DEFAULT_WORKLOAD_MODEL=open
K6_DOCKER_IMAGE=grafana/k6:latest
JMETER_DOCKER_IMAGE=alpine/jmeter:5.6.3
PERF_ENGINE_PULL_POLICY=missing
PERFORMANCE_RUNNER_DOCKER_CPUS=
PERFORMANCE_RUNNER_DOCKER_MEMORY=
PERFORMANCE_MAX_CONCURRENT_RUNS=1
PERFORMANCE_REWRITE_LOCALHOST=true
PERFORMANCE_SMOKE_REQUIRED=true
PERFORMANCE_SMOKE_ITERATIONS=3
PERFORMANCE_TARGET_ALLOWLIST=
PERFORMANCE_MAX_VUS=2000
PERFORMANCE_MAX_RATE_RPS=1000
PERFORMANCE_MAX_DURATION_SECONDS=1800
PERFORMANCE_RUNNER_DOCKER_CONTAINER_PREFIX=qa-perf
PERFORMANCE_RUNNER_DOCKER_WORKDIR=/work
POSTGRES_PERF_RUNS_TABLE=agent_perf_runs

# OAuth 2.0 Credentials
# AZURE
OAUTH_AZURE_AD_CLIENT_ID=
OAUTH_AZURE_AD_CLIENT_SECRET=
OAUTH_AZURE_AD_TENANT_ID=common

# GOOGLE
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# GITHUB
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# CODEBUDDY
OAUTH_CODEBUDDY_CLIENT_ID=
OAUTH_CODEBUDDY_CLIENT_SECRET=
OAUTH_CODEBUDDY_POLL_URL=
OAUTH_CODEBUDDY_MODELS_ENDPOINT=

# TRAE
OAUTH_TRAE_CLIENT_ID=
OAUTH_TRAE_CLIENT_SECRET=

# CODEX
OAUTH_CODEX_CLIENT_ID=
OAUTH_CODEX_CLIENT_SECRET=
